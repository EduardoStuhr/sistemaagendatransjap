# ── Banco de dados ────────────────────────────────────
# SQLite (dev): file:./dev.db
# PostgreSQL (prod): postgresql://user:password@host:5432/dbname
DATABASE_URL="file:./dev.db"

# ── JWT ───────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="GERE_UM_SEGREDO_FORTE_AQUI"
JWT_EXPIRES_IN="7d"

# ── Servidor ──────────────────────────────────────────
PORT=3001
CLIENT_URL="http://localhost:5173"

# ── SMTP (opcional — sem isso o código aparece só no console) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Transjap <noreply@transjap.com.br>"

# ── Ambiente ──────────────────────────────────────────
NODE_ENV=development
