generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("tecnico")
  initials  String
  color     String   @default("#388bfd")
  isAdmin   Boolean  @default(false)
  isManager Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasksSent      Task[]               @relation("TaskFrom")
  taskRecipients TaskRecipient[]
  comments       Comment[]
  notifications  Notification[]
  taskViews      TaskView[]
  despesas       Despesa[]
  importacoes    ImportacaoDespesa[]
  attachments    TaskAttachment[]
}

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  priority    String    @default("media")
  requestType String    @default("Manutenção")
  status      String    @default("nao_visualizada")
  maintenanceStatus String?
  category    String    @default("manutencao")
  dueDate      DateTime?
  budgetRequestedAt    DateTime?
  budgetApprovedAt     DateTime?
  partsRequestedAt     DateTime?
  partsPurchasedAt     DateTime?
  partsDeliveredAt     DateTime?
  maintenanceStartedAt DateTime?
  maintenanceFinishedAt DateTime?
  deliveryForecast     DateTime?
  deliveryDate         DateTime?
  delayReason          String?
  supplierName         String?
  totalStoppedDays     Int?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  fromId Int
  from   User @relation("TaskFrom", fields: [fromId], references: [id])

  recipients   TaskRecipient[]
  comments     Comment[]
  history      TaskHistory[]
  views        TaskView[]
  attachments  TaskAttachment[]
}

model TaskRecipient {
  id     Int  @id @default(autoincrement())
  taskId Int
  userId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  taskId    Int
  userId    Int
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskHistory {
  id        Int      @id @default(autoincrement())
  action    String
  taskId    Int
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskView {
  id       Int      @id @default(autoincrement())
  taskId   Int
  userId   Int
  viewedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  type      String   @default("info")
  read      Boolean  @default(false)
  userId    Int
  taskId    Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskAttachment {
  id           Int      @id @default(autoincrement())
  taskId       Int
  uploadedById Int
  fileName     String
  fileSize     Int
  mimeType     String
  storagePath  String
  createdAt    DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])
}

model Part {
  id          Int      @id @default(autoincrement())
  name        String
  code        String?
  description String?
  quantity    Int      @default(0)
  unit        String   @default("un")
  location    String?
  minStock    Int      @default(0)
  supplier    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Despesa {
  id             Int      @id @default(autoincrement())
  data           DateTime
  centroCusto    String
  tipoDespesa    String?
  setorDespesa   String?
  numFrota       String?
  tipoFrota      String?
  descricaoFrota String?
  fornecedor     String?
  descricao      String
  valor          Float
  importadoEm    DateTime @default(now())

  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id])
}

model ImportacaoDespesa {
  id          Int      @id @default(autoincrement())
  fileName    String
  totalLinhas Int
  totalValor  Float
  importadoEm DateTime @default(now())
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
}
